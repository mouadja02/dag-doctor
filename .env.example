# =============================================================================
# dag-doctor — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Airflow Connection (TEST CLONE ONLY) ---
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# --- LLM Provider (OpenRouter) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Database ---
# SQLite (default for dev/demo):
DATABASE_URL=sqlite:///data/dag_doctor.db
# PostgreSQL (for shared deployments):
# DATABASE_URL=postgresql://dagdoctor:dagdoctor@localhost:5432/dagdoctor

# --- Authentication ---
SECRET_KEY=change-this-to-a-real-secret-in-production
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Security ---
# ALLOWED_ORIGINS=["http://localhost:8501"]
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD_SECONDS=60
# LLM_REDACTION_LEVEL=standard
# RETENTION_DAYS=90

# --- Integrations (optional) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# JIRA_API_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=user@example.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT_KEY=DD

# --- Optional: Local log volume path (for file system fallback) ---
LOG_VOLUME_PATH=

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Demo Mode ---
# DEMO_MODE=true
# LLM_ENABLED=true
