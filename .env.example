# =============================================================================
# dag-doctor — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Airflow Connection (TEST CLONE ONLY) ---
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# --- LLM Provider (OpenRouter) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Alternative models:
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# --- Optional: Local log volume path (for file system fallback) ---
# If your test Airflow instance shares a Docker volume, set this to the
# host path where logs are stored (e.g., ./docker/data/airflow/logs).
LOG_VOLUME_PATH=

# --- Database (SQLite for MVP) ---
DATABASE_URL=sqlite:///data/dag_doctor.db

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
